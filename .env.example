# SQLite — no setup needed, just a local file.
# To switch to PostgreSQL uncomment the line below and comment out the SQLite one.
DATABASE_URL=sqlite+aiosqlite:///./strawpoll.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/strawpoll

ANTHROPIC_API_KEY=your-anthropic-api-key-here
LEGISCAN_API_KEY=your-legiscan-api-key-here
CONGRESS_GOV_API_KEY=your-congress-gov-api-key-here

# Free FEC API key — sign up at https://api.data.gov/signup/ (instant, no review)
# Allows 1000 req/hour vs 60/hour for the DEMO_KEY default
FEC_API_KEY=DEMO_KEY
